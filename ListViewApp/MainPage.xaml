<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ListViewApp.MainPage"
    BindingContext="{Binding Source={RelativeSource Self}}">

    <ScrollView>
        <VerticalStackLayout Margin="60,0" Spacing="25">
            <Button Text="Refresh" Clicked="Button_Clicked" />

            <Border
                HorizontalOptions="Fill"
                Stroke="{StaticResource PrimaryBrush}"
                HeightRequest="150"
                Padding="2"
                Margin="0,5,0,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="5" />
                </Border.StrokeShape>
                <CollectionView
                    ItemsSource="{Binding Devices}"
                    SelectionMode="Single">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Horizontal" HorizontalItemSpacing="2" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Stroke="DeepPink"
                                HeightRequest="140"
                                WidthRequest="140">
                                <Grid HorizontalOptions="Center" MaximumHeightRequest="140">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="2*" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <!--  Clipboard: Text="&#x1F4CB;"  -->
                                    <!--  Rocket: &#x1F680;  -->
                                    <Label
                                        Text="{Binding Device.DeviceName}"
                                        FontSize="40"
                                        VerticalOptions="Center" />

                                    <Label
                                        Text="{Binding Device.DevicePlatform}"
                                        HorizontalOptions="Center"
                                        Grid.Row="1" />
                                </Grid>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="5" />
                                </Border.StrokeShape>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
